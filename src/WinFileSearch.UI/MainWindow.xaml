<Window x:Class="WinFileSearch.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinFileSearch.UI"
        xmlns:views="clr-namespace:WinFileSearch.UI.Views"
        mc:Ignorable="d"
        Title="WinFileSearch" 
        Height="700" Width="1000"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <!-- Keyboard Shortcuts -->
    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding NavigateToSearchCommand}"/>
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{Binding NavigateToHomeCommand}"/>
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{Binding NavigateToSearchCommand}"/>
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{Binding NavigateToRecentCommand}"/>
        <KeyBinding Key="D4" Modifiers="Ctrl" Command="{Binding NavigateToSettingsCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Content Area -->
        <Frame x:Name="MainFrame" 
               Grid.Row="0"
               NavigationUIVisibility="Hidden"
               Background="Transparent"/>

        <!-- Bottom Navigation Bar -->
        <Border Grid.Row="1" 
                Background="{StaticResource SecondaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Home Button -->
                <RadioButton x:Name="HomeNav" 
                             Grid.Column="0" 
                             Style="{StaticResource NavButtonStyle}"
                             Tag="Home"
                             IsChecked="True"
                             Checked="HomeNav_Checked">
                    <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          Width="20" Height="20" Stretch="Uniform"/>
                </RadioButton>

                <!-- Search Button -->
                <RadioButton x:Name="SearchNav" 
                             Grid.Column="1" 
                             Style="{StaticResource NavButtonStyle}"
                             Tag="Search"
                             Checked="SearchNav_Checked">
                    <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          Width="20" Height="20" Stretch="Uniform"/>
                </RadioButton>

                <!-- Recent Button -->
                <RadioButton x:Name="RecentNav" 
                             Grid.Column="2" 
                             Style="{StaticResource NavButtonStyle}"
                             Tag="Recent"
                             Checked="RecentNav_Checked">
                    <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          Width="20" Height="20" Stretch="Uniform"/>
                </RadioButton>

                <!-- Settings Button -->
                <RadioButton x:Name="SettingsNav" 
                             Grid.Column="3" 
                             Style="{StaticResource NavButtonStyle}"
                             Tag="Settings"
                             Checked="SettingsNav_Checked">
                    <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          Width="20" Height="20" Stretch="Uniform"/>
                </RadioButton>
            </Grid>
        </Border>
    </Grid>
</Window>
