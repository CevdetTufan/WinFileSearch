<Page x:Class="WinFileSearch.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:WinFileSearch.UI.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Background="{StaticResource PrimaryBackgroundBrush}"
      Title="Settings">

    <Page.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <TextBlock Text="Indexing Settings" 
                           FontSize="22" 
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
            </Grid>

            <!-- General Section -->
            <TextBlock Text="GENERAL" 
                       FontSize="11" 
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Margin="0,0,0,12"/>

            <!-- Background Indexing Toggle -->
            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Background Indexing" 
                                   FontSize="14" 
                                   FontWeight="Medium"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Allow the app to update file records while minimized" 
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" 
                              Style="{StaticResource ToggleSwitchStyle}"
                              IsChecked="{Binding BackgroundIndexingEnabled}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Start with Windows Toggle -->
            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Start with Windows" 
                                   FontSize="14" 
                                   FontWeight="Medium"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Launch WinFileSearch automatically when Windows starts" 
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" 
                              Style="{StaticResource ToggleSwitchStyle}"
                              IsChecked="{Binding StartWithWindows}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Minimize to Tray Toggle -->
            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Minimize to System Tray" 
                                   FontSize="14" 
                                   FontWeight="Medium"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Keep running in background when window is closed" 
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" 
                              Style="{StaticResource ToggleSwitchStyle}"
                              IsChecked="{Binding MinimizeToTray}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Language Selection -->
            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Language" 
                                   FontSize="14" 
                                   FontWeight="Medium"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="Select your preferred language" 
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailableLanguages}"
                              SelectedValue="{Binding SelectedLanguage}"
                              SelectedValuePath="Code"
                              DisplayMemberPath="Name"
                              Width="120"
                              VerticalAlignment="Center"
                              Background="{StaticResource SecondaryBackgroundBrush}"
                              Foreground="{StaticResource PrimaryTextBrush}"/>
                </Grid>
            </Border>

            <!-- Rebuild Index -->
            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Rebuild Index" 
                               FontSize="14" 
                               FontWeight="Medium"
                               Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Clear current database and start a fresh scan of all folders" 
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,4,0,12"/>
                    
                    <!-- Progress Bar (visible during indexing) -->
                    <ProgressBar Style="{StaticResource IndexingProgressBarStyle}"
                                 Value="{Binding IndexingProgress}"
                                 Maximum="100"
                                 Margin="0,0,0,8"
                                 Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    
                    <TextBlock Text="{Binding IndexingStatus}"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,0,0,12"
                               Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Button Command="{Binding RebuildIndexCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Content" Value="Rebuild Database Now"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIndexing}" Value="True">
                                        <Setter Property="Content" Value="Cancel Rebuild"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Included Folders Section -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="INCLUDED FOLDERS" 
                           FontSize="11" 
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="⊕ Add Folder"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding AddFolderCommand}"/>
            </Grid>

            <!-- Drag & Drop Zone -->
            <Border x:Name="DropZone"
                    Style="{StaticResource CardPanelStyle}"
                    BorderThickness="2"
                    BorderBrush="{StaticResource SecondaryBackgroundBrush}"
                    Margin="0,0,0,12"
                    MinHeight="100"
                    AllowDrop="True"
                    DragEnter="DropZone_DragEnter"
                    DragLeave="DropZone_DragLeave"
                    Drop="DropZone_Drop">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                          Fill="{StaticResource SecondaryTextBrush}"
                          Width="32" Height="32"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,12"/>
                    <TextBlock Text="Drag and drop folders here"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="or use the 'Add Folder' button above"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Opacity="0.7"/>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding IncludedFolders}" Margin="0,0,0,24">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Folder Icon -->
                                <Path Grid.Column="0"
                                      Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                      Fill="{StaticResource FolderIconBrush}"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      Margin="0,0,12,0"/>

                                <!-- Folder Info -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Path}"
                                               FontSize="14"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock FontSize="12" Foreground="{StaticResource SecondaryTextBrush}">
                                            <Run Text="{Binding FileCount, StringFormat='{}{0:N0} files'}"/>
                                            <Run Text=" • "/>
                                            <Run Text="{Binding TotalSize, Converter={StaticResource FileSizeConverter}}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Remove Button -->
                                <Button Grid.Column="2"
                                        Content="⊖"
                                        FontSize="18"
                                        Background="Transparent"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Excluded Folders Section -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="EXCLUDED FOLDERS" 
                           FontSize="11" 
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="⊕ Add Exclusion"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding AddExclusionCommand}"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding ExcludedFolders}" Margin="0,0,0,24">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Excluded Folder Icon -->
                                <Path Grid.Column="0"
                                      Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                                      Fill="{StaticResource SecondaryTextBrush}"
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      Margin="0,0,12,0"
                                      Opacity="0.5"/>

                                <!-- Folder Info -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Path}"
                                               FontSize="14"
                                               Foreground="{StaticResource PrimaryTextBrush}"/>
                                    <TextBlock Text="Excluded from indexing"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Remove Button -->
                                <Button Grid.Column="2"
                                        Content="⊖"
                                        FontSize="18"
                                        Background="Transparent"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.RemoveExclusionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Stats -->
            <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}">
                    <Run Text="Last indexed: "/>
                    <Run Text="{Binding LastIndexed, StringFormat='MMM d, yyyy h:mm tt', TargetNullValue='Never'}"/>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,4,0,0">
                    <Run Text="Total files indexed: "/>
                    <Run Text="{Binding TotalFilesIndexed, StringFormat='{}{0:N0}'}"/>
                </TextBlock>
            </StackPanel>

            <!-- Performance Metrics Section -->
            <TextBlock Text="PERFORMANCE METRICS" 
                       FontSize="11" 
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Margin="0,24,0,12"/>

            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Total Searches -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Total Searches" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding TotalSearches}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>

                    <!-- Avg Search Time -->
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Avg Search Time" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}">
                            <Run Text="{Binding AverageSearchTimeMs}"/><Run Text=" ms"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Memory Usage -->
                    <StackPanel Grid.Column="0" Grid.Row="1">
                        <TextBlock Text="Memory Usage" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}">
                            <Run Text="{Binding MemoryUsageMB}"/><Run Text=" MB"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Uptime -->
                    <StackPanel Grid.Column="1" Grid.Row="1">
                        <TextBlock Text="Uptime" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding Uptime}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Button Content="Refresh Metrics" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshMetricsCommand}"
                        Margin="0,0,12,0"/>
                <Button Content="Open Log Folder" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding OpenLogFolderCommand}"/>
            </StackPanel>

            <!-- About & Updates Section -->
            <TextBlock Text="ABOUT &amp; UPDATES" 
                       FontSize="11" 
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Margin="0,24,0,12"/>

            <Border Style="{StaticResource CardPanelStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Current Version -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="WinFileSearch" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,4,0,0">
                                <Run Text="Current Version: "/>
                                <Run Text="{Binding CurrentVersion}"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Check for Updates"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CheckForUpdatesCommand}"/>
                    </Grid>

                    <!-- Update Available Banner -->
                    <Border Background="#1E4CAF50" 
                            CornerRadius="8" 
                            Padding="16"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Update Info -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#4CAF50">
                                    <Run Text="🎉 New Version Available: "/>
                                    <Run Text="{Binding LatestVersion}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Release Notes Preview -->
                            <TextBlock Grid.Row="1" 
                                       Text="{Binding UpdateReleaseNotes}" 
                                       TextWrapping="Wrap"
                                       MaxHeight="80"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,0,0,12"/>

                            <!-- Download Progress (shown when downloading) -->
                            <StackPanel Grid.Row="2" 
                                        Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Downloading update..." 
                                           FontSize="12" 
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,8"/>
                                <ProgressBar Value="{Binding DownloadProgress}" 
                                             Minimum="0" 
                                             Maximum="100" 
                                             Height="6"
                                             Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>

                            <!-- Action Buttons (hidden when downloading) -->
                            <StackPanel Grid.Row="2" 
                                        Orientation="Horizontal" 
                                        HorizontalAlignment="Right">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDownloadingUpdate}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Button Content="View on GitHub"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding OpenReleasePageCommand}"
                                        Margin="0,0,12,0"/>
                                <Button Content="Download &amp; Install"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding DownloadAndInstallUpdateCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
