<Page x:Class="WinFileSearch.UI.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:WinFileSearch.UI.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Background="{StaticResource PrimaryBackgroundBrush}"
      Title="Home">

    <Page.Resources>
        <converters:FileCategoryToIconConverter x:Key="CategoryToIconConverter"/>
        <converters:FileCategoryToBrushConverter x:Key="CategoryToBrushConverter"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,20,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo and Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Width="40" Height="40" 
                        CornerRadius="10"
                        Background="{StaticResource AccentBrush}">
                    <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                          Fill="White"
                          Width="20" Height="20"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Index Manager" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Windows File Search" 
                               FontSize="11"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Stats -->
            <TextBlock Grid.Column="2" 
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource SecondaryTextBrush}">
                <Run Text="{Binding TotalFilesIndexed, StringFormat='{}{0:N0}'}"/>
                <Run Text=" files indexed"/>
            </TextBlock>
        </Grid>

        <!-- Search Box -->
        <Grid Grid.Row="1" Margin="20,20,20,0">
            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{x:Null}"/>
                </TextBox.InputBindings>
            </TextBox>
            <TextBlock Text="🔍 Search files, folders, metadata..."
                       IsHitTestVisible="False"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       Visibility="{Binding SearchQuery, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
        </Grid>

        <!-- Category Filters -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,16,20,0">
            <ToggleButton Content="📄 All Files" 
                          Style="{StaticResource FilterButtonStyle}"
                          IsChecked="True"
                          Command="{Binding SetCategoryAllCommand}"
                          Margin="0,0,8,0"/>
            
            <ToggleButton Content="📝 Documents" 
                          Style="{StaticResource FilterButtonStyle}"
                          Command="{Binding SetCategoryDocumentsCommand}"
                          Margin="0,0,8,0"/>
            
            <ToggleButton Content="🖼️ Images" 
                          Style="{StaticResource FilterButtonStyle}"
                          Command="{Binding SetCategoryImagesCommand}"
                          Margin="0,0,8,0"/>
            
            <ToggleButton Content="🎬 Media" 
                          Style="{StaticResource FilterButtonStyle}"
                          Command="{Binding SetCategoryMediaCommand}"/>
        </StackPanel>

        <!-- Recently Indexed Section -->
        <Grid Grid.Row="3" Margin="20,24,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Section Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="RECENTLY INDEXED" 
                           FontSize="11" 
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
                <TextBlock Text="View All" 
                           HorizontalAlignment="Right"
                           FontSize="12"
                           Foreground="{StaticResource AccentBrush}"
                           Cursor="Hand"/>
            </Grid>

            <!-- Recent Files List -->
            <ListBox Grid.Row="1"
                     Style="{StaticResource FileListBoxStyle}"
                     ItemsSource="{Binding RecentFiles}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                              CommandParameter="{Binding}"/>
                            </Grid.InputBindings>

                            <!-- File Icon -->
                            <Border Grid.Column="0" Grid.RowSpan="2"
                                    Width="40" Height="40"
                                    CornerRadius="8"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    Margin="0,0,12,0">
                                <Path Data="{Binding Category, Converter={StaticResource CategoryToIconConverter}}"
                                      Fill="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>

                            <!-- File Name -->
                            <TextBlock Grid.Column="1" Grid.Row="0"
                                       Text="{Binding FileName}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- File Info -->
                            <StackPanel Grid.Column="1" Grid.Row="1"
                                        Orientation="Horizontal"
                                        Margin="0,2,0,0">
                                <TextBlock Text="{Binding Size, Converter={StaticResource FileSizeConverter}}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Text=" • "
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding Extension, StringFormat='{}{0} File'}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                            </StackPanel>

                            <!-- Time -->
                            <TextBlock Grid.Column="2" Grid.RowSpan="2"
                                       Text="{Binding ModifiedAt, Converter={StaticResource RelativeTimeConverter}}"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty State -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding RecentFiles.Count, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                <TextBlock Text="No files indexed yet"
                           FontSize="16"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Go to Settings to add folders for indexing"
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Indexing Progress Bar -->
        <Border Grid.Row="4" 
                Background="{StaticResource SecondaryBackgroundBrush}"
                Padding="20,12"
                Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding IndexingStatus}"
                               FontSize="12"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Margin="0,0,0,6"/>
                    <ProgressBar Style="{StaticResource IndexingProgressBarStyle}"
                                 Value="{Binding IndexingProgress}"
                                 Maximum="100"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding IndexingProgress, StringFormat='{}{0:F0}%'}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Page>
