<Page x:Class="WinFileSearch.UI.Views.SearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:WinFileSearch.UI.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Background="{StaticResource PrimaryBackgroundBrush}"
      Title="Search">

    <Page.Resources>
        <converters:FileCategoryToIconConverter x:Key="CategoryToIconConverter"/>
        <converters:FileCategoryToBrushConverter x:Key="CategoryToBrushConverter"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ImagePreviewConverter x:Key="ImagePreviewConverter"/>
        <converters:TextPreviewConverter x:Key="TextPreviewConverter"/>
        <converters:IsImageFileConverter x:Key="IsImageFileConverter"/>
        <converters:IsTextFileConverter x:Key="IsTextFileConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" 
                       Text="Search Results" 
                       FontSize="22" 
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryTextBrush}"/>
            
            <!-- Search Stats -->
            <TextBlock Grid.Column="2" 
                       Text="{Binding StatusMessage}"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Search Box and Filters -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <!-- Search TextBox with History Dropdown -->
            <Grid>
                <TextBox x:Name="SearchTextBox"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Search files, folders, metadata..."
                         GotFocus="SearchTextBox_GotFocus"/>

                <!-- Search History Popup -->
                <Popup x:Name="HistoryPopup"
                       PlacementTarget="{Binding ElementName=SearchTextBox}"
                       Placement="Bottom"
                       IsOpen="{Binding ShowHistory}"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Width="{Binding ActualWidth, ElementName=SearchTextBox}"
                            MaxHeight="300">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Grid Grid.Row="0" Margin="12,8">
                                <TextBlock Text="Recent Searches"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>
                                <Button Content="Clear"
                                        HorizontalAlignment="Right"
                                        Background="Transparent"
                                        Foreground="{StaticResource AccentBrush}"
                                        BorderThickness="0"
                                        FontSize="11"
                                        Cursor="Hand"
                                        Command="{Binding ClearHistoryCommand}"/>
                            </Grid>

                            <!-- History Items -->
                            <ItemsControl Grid.Row="1" 
                                          ItemsSource="{Binding SearchHistory}"
                                          Margin="4,0,4,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                HorizontalContentAlignment="Left"
                                                Padding="12,8"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.SelectHistoryItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"
                                                      Fill="{StaticResource SecondaryTextBrush}"
                                                      Width="14" Height="14"
                                                      Stretch="Uniform"
                                                      Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="13"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>

            <!-- Category Filters -->
            <StackPanel Orientation="Horizontal" Margin="0,12,0,8">
                <ToggleButton Content="📄 All Files" 
                              Style="{StaticResource FilterButtonStyle}"
                              IsChecked="{Binding SelectedCategory, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=null}"
                              Command="{Binding SetCategoryAllCommand}"
                              Margin="0,0,8,0"/>

                <ToggleButton Content="📝 Documents" 
                              Style="{StaticResource FilterButtonStyle}"
                              Command="{Binding SetCategoryDocumentsCommand}"
                              Margin="0,0,8,0"/>

                <ToggleButton Content="🖼️ Images"
                              Style="{StaticResource FilterButtonStyle}"
                              Command="{Binding SetCategoryImagesCommand}"
                              Margin="0,0,8,0"/>
                
                <ToggleButton Content="🎬 Media" 
                              Style="{StaticResource FilterButtonStyle}"
                              Command="{Binding SetCategoryMediaCommand}"/>
            </StackPanel>
        </StackPanel>

        <!-- Results List -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- File List -->
            <ListBox Grid.Column="0"
                     Style="{StaticResource FileListBoxStyle}"
                     ItemsSource="{Binding SearchResults}"
                     SelectedItem="{Binding SelectedFile}">
                <ListBox.ContextMenu>
                    <ContextMenu Background="{StaticResource CardBackgroundBrush}"
                                 BorderBrush="{StaticResource BorderBrush}">
                        <MenuItem Header="Open File" 
                                  Command="{Binding OpenSelectedFileCommand}"
                                  Foreground="{StaticResource PrimaryTextBrush}"/>
                        <MenuItem Header="Open File Location" 
                                  Command="{Binding OpenFileLocationCommand}"
                                  Foreground="{StaticResource PrimaryTextBrush}"/>
                        <Separator Background="{StaticResource BorderBrush}"/>
                        <MenuItem Header="Copy Full Path" 
                                  Command="{Binding CopyPathCommand}"
                                  Foreground="{StaticResource PrimaryTextBrush}"/>
                        <MenuItem Header="Copy File Name" 
                                  Command="{Binding CopyFileNameCommand}"
                                  Foreground="{StaticResource PrimaryTextBrush}"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- File Icon -->
                            <Border Grid.Column="0" Grid.RowSpan="2"
                                    Width="40" Height="40"
                                    CornerRadius="8"
                                    Background="{StaticResource CardBackgroundBrush}"
                                    Margin="0,0,12,0">
                                <Path Data="{Binding Category, Converter={StaticResource CategoryToIconConverter}}"
                                      Fill="{Binding Category, Converter={StaticResource CategoryToBrushConverter}}"
                                      Width="20" Height="20"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>

                            <!-- File Name -->
                            <TextBlock Grid.Column="1" Grid.Row="0"
                                       Text="{Binding FileName}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- File Path -->
                            <TextBlock Grid.Column="1" Grid.Row="1"
                                       Text="{Binding Directory}"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,2,0,0"/>

                            <!-- File Info -->
                            <StackPanel Grid.Column="2" Grid.RowSpan="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Size, Converter={StaticResource FileSizeConverter}}"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding ModifiedAt, Converter={StaticResource RelativeTimeConverter}}"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           HorizontalAlignment="Right"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Quick Preview Panel -->
            <Border Grid.Column="1"
                    Width="300"
                    Margin="16,0,0,0"
                    Style="{StaticResource CardPanelStyle}"
                    Visibility="{Binding ShowPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="QUICK PREVIEW" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <Button Content="✕" 
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding ClosePreviewCommand}"/>
                    </Grid>

                    <!-- File Icon and Name -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="50" Height="50"
                                CornerRadius="10"
                                Background="{StaticResource SecondaryBackgroundBrush}">
                            <Path Data="{Binding SelectedFile.Category, Converter={StaticResource CategoryToIconConverter}}"
                                  Fill="{Binding SelectedFile.Category, Converter={StaticResource CategoryToBrushConverter}}"
                                  Width="24" Height="24"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding SelectedFile.FileName}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   TextWrapping="Wrap"
                                   MaxWidth="200"/>
                    </StackPanel>

                    <!-- File Details with Preview -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Image Preview -->
                            <Border Margin="0,0,0,12"
                                    CornerRadius="8"
                                    Background="{StaticResource SecondaryBackgroundBrush}"
                                    Visibility="{Binding SelectedFile.FullPath, Converter={StaticResource IsImageFileConverter}, ConverterParameter=ToVisibility}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFile.FullPath, Converter={StaticResource IsImageFileConverter}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedFile.FullPath, Converter={StaticResource IsImageFileConverter}}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Image Source="{Binding SelectedFile.FullPath, Converter={StaticResource ImagePreviewConverter}}"
                                       MaxHeight="150"
                                       Stretch="Uniform"
                                       Margin="8"/>
                            </Border>

                            <!-- Text Preview -->
                            <Border Margin="0,0,0,12"
                                    Padding="10"
                                    CornerRadius="8"
                                    Background="{StaticResource SecondaryBackgroundBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFile.FullPath, Converter={StaticResource IsTextFileConverter}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedFile.FullPath, Converter={StaticResource IsTextFileConverter}}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="PREVIEW" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding SelectedFile.FullPath, Converter={StaticResource TextPreviewConverter}}"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"
                                               MaxHeight="120"/>
                                </StackPanel>
                            </Border>

                            <!-- File Info -->
                            <TextBlock Text="TYPE" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding SelectedFile.Extension}" FontSize="13" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                            <TextBlock Text="SIZE" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding SelectedFile.Size, Converter={StaticResource FileSizeConverter}}" FontSize="13" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                            <TextBlock Text="MODIFIED" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding SelectedFile.ModifiedAt, Converter={StaticResource RelativeTimeConverter}}" FontSize="13" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                            <TextBlock Text="LOCATION" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding SelectedFile.Directory}" FontSize="12" Foreground="{StaticResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Actions -->
                    <StackPanel Grid.Row="3" Margin="0,16,0,0">
                        <Button Content="Open File" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding OpenSelectedFileCommand}"
                                Margin="0,0,0,8"/>
                        <Button Content="Open Location" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenFileLocationCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Indicator -->
        <Border Grid.Row="2" 
                Background="#80000000"
                Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Searching..." 
                           FontSize="16" 
                           Foreground="{StaticResource PrimaryTextBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
